{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@bytes/common": ["../common/src/server.ts"]
    }
  },
  "include": ["src", "server.ts"],
  "exclude": ["node_modules", "dist"]
}